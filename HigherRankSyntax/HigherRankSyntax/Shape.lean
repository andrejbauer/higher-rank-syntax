import HigherRankSyntax.Carrier

/-!
# Shapes and slots

The framework-level data on top of a `Carrier`.

* **Shapes.**  `Shape C` is the inductive type generated by the carrier's base shapes
  (`.base Î³`) and one-step extension by an arity (`.ext Î“ Î±`, notation `Î“ â‹ˆ Î±`).

* **Slots.**  `Slot Î“` is inductively the slots of `Î“`, with one constructor per layer:
  `.base x` for a variable of the base shape, `.here i` for a binder introduced at this
  `ext` layer, `.there p` for a slot inherited from the shape below.

* **Slot arity.**  `Slot.arity` reads off the arity of a slot by recursion: a base slot
  uses the variable's `arity`, a `.here` binder uses the binder's `arity`, a `.there`
  slot inherits from the shape below.  The equations hold by `rfl`.
-/


/-- A shape over a carrier `C`: either a base shape, or a one-step extension `Î“ â‹ˆ Î±`. -/
inductive Shape (C : Carrier) where
  /-- The base shape associated with `Î³ : C.BaseShape`. -/
  | base : (Î³ : C.BaseShape) â†’ Shape C
  /-- Extension of a shape by all the binders of an arity. -/
  | ext  : (Î“ : Shape C) â†’ (Î± : C.Arity) â†’ Shape C

/-- Action of an arity on a shape. -/
infixl:65 " â‹ˆ " => Shape.ext

/-- A slot of a shape with its arity tracked as a type index: a variable of the base
layer (`.base x` at `x.arity`), a fresh binder of the topmost extension (`.here i` at
`i.arity`), or a slot inherited from the shape below (`.there p` at the same arity as
`p`). -/
inductive SlotAt {C : Carrier} : Shape C â†’ C.Arity â†’ Type where
  /-- A variable of the base shape at its variable's arity. -/
  | base  : {Î³ : C.BaseShape} â†’ (x : C.Var Î³) â†’ SlotAt (.base Î³) x.arity
  /-- A binder introduced by the topmost extension at its binder's arity. -/
  | here  : {Î“ : Shape C} â†’ {Î± : C.Arity} â†’ (i : C.Binder Î±) â†’ SlotAt (Î“ â‹ˆ Î±) i.arity
  /-- A slot inherited from the shape below the topmost extension, at the same arity. -/
  | there : {Î“ : Shape C} â†’ {Î² Î± : C.Arity} â†’ SlotAt Î“ Î± â†’ SlotAt (Î“ â‹ˆ Î²) Î±

/-- `Î“ âˆ‹ Î±` is the type of slots of `Î“` at arity `Î±`. -/
notation:35 Î“ " âˆ‹ " Î± => SlotAt Î“ Î±

/-- Extract the arity index from a slot. -/
@[reducible]
def SlotAt.arity {C : Carrier} {Î“ : Shape C} {Î± : C.Arity} (_ : Î“ âˆ‹ Î±) : C.Arity := Î±

/-- Iterated extension of a shape by a list of arities, cons-as-snoc: the head of the list
is the outermost extension.  `Î“ â‹ˆ* (Î² :: rest) := (Î“ â‹ˆ* rest) â‹ˆ Î²` and `Î“ â‹ˆ* [] := Î“`. -/
def Shape.extList {C : Carrier} (Î“ : Shape C) : List C.Arity â†’ Shape C
  | []        => Î“
  | Î² :: rest => (Shape.extList Î“ rest) â‹ˆ Î²

/-- Iterated extension of a shape by a list of arities. -/
infixl:67 " â‹ˆ* " => Shape.extList

@[simp] theorem Shape.extList_nil {C : Carrier} (Î“ : Shape C) : Î“ â‹ˆ* [] = Î“ := rfl

@[simp] theorem Shape.extList_cons {C : Carrier} (Î“ : Shape C) (Î² : C.Arity)
    (rest : List C.Arity) : Î“ â‹ˆ* (Î² :: rest) = (Î“ â‹ˆ* rest) â‹ˆ Î² := rfl

/-- Associativity of iterated extension w.r.t. list append: extending by `ys` then by
`xs` equals extending by `xs ++ ys`.  Reduces to `rfl` when `xs = []`. -/
theorem Shape.extList_append {C : Carrier} (Î“ : Shape C) :
    âˆ€ (xs ys : List C.Arity), (Î“ â‹ˆ* ys) â‹ˆ* xs = Î“ â‹ˆ* (xs ++ ys)
  | [],        _  => rfl
  | x :: xs',  ys => by
    show ((Î“ â‹ˆ* ys) â‹ˆ* xs') â‹ˆ x = (Î“ â‹ˆ* (xs' ++ ys)) â‹ˆ x
    rw [Shape.extList_append Î“ xs' ys]

