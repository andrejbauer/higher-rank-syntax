import HigherRankSyntax.Action.Carrier

/-!
# Shapes and slots

The framework-level data on top of a `Carrier`.

* **Shapes.**  `Shape C` is the inductive type generated by the carrier's base shapes
  (`.base ־³`) and one-step extension by an arity (`.ext ־“ ־±`, notation `־“ ג‹ˆ ־±`).

* **Slots.**  `Slot ־“` is inductively the slots of `־“`, with one constructor per layer:
  `.base p` for a variable of the base shape, `.here z` for a binder introduced at this
  `ext` layer, `.there s` for a slot inherited from the shape below.

* **Slot arity.**  `Slot.arity` reads off the arity of a slot by recursion: a base slot
  uses `baseSlotArity`, a `.here` binder uses `arityArity`, a `.there` slot inherits from
  the shape below.  The equations hold by `rfl`.
-/

namespace Action

/-- A shape over a carrier `C`: either a base shape, or a one-step extension `־“ ג‹ˆ ־±`. -/
inductive Shape (C : Carrier) where
  /-- The base shape associated with `־³ : C.BaseShape`. -/
  | base : (־³ : C.BaseShape) ג†’ Shape C
  /-- Extension of a shape by all the binders of an arity. -/
  | ext  : (־“ : Shape C) ג†’ (־± : C.Arity) ג†’ Shape C

/-- Action of an arity on a shape. -/
scoped infixl:65 " ג‹ˆ " => Shape.ext

/-- A slot of a shape: a variable of the base layer, a fresh binder of the topmost
extension, or a slot inherited from the shape below. -/
inductive Slot {C : Carrier} : Shape C ג†’ Type where
  /-- A variable of the base shape. -/
  | base  : {־³ : C.BaseShape} ג†’ (p : C.BaseShapeSlot ־³) ג†’ Slot (.base ־³)
  /-- A binder introduced by the topmost extension. -/
  | here  : {־“ : Shape C} ג†’ {־± : C.Arity} ג†’ (z : C.AritySlot ־±) ג†’ Slot (־“ ג‹ˆ ־±)
  /-- A slot inherited from the shape below the topmost extension. -/
  | there : {־“ : Shape C} ג†’ {־± : C.Arity} ג†’ (s : Slot ־“) ג†’ Slot (־“ ג‹ˆ ־±)

/-- The arity of a slot, by recursion on its constructors. -/
def Slot.arity {C : Carrier} {־“ : Shape C} : Slot ־“ ג†’ C.Arity
  | .base p  => C.baseSlotArity _ p
  | .here z  => C.arityArity _ z
  | .there s => s.arity

@[simp] theorem Slot.arity_base {C : Carrier} {־³ : C.BaseShape} (p : C.BaseShapeSlot ־³) :
    (Slot.base (C := C) p).arity = C.baseSlotArity ־³ p := rfl

@[simp] theorem Slot.arity_here {C : Carrier} {־“ : Shape C} {־± : C.Arity}
    (z : C.AritySlot ־±) : (Slot.here (־“ := ־“) z).arity = C.arityArity ־± z := rfl

@[simp] theorem Slot.arity_there {C : Carrier} {־“ : Shape C} {־± : C.Arity}
    (s : Slot ־“) : (Slot.there (־± := ־±) s).arity = s.arity := rfl

/-- Iterated extension of a shape by a list of arities, cons-as-snoc: the head of the list
is the outermost extension.  `־“ ג‹ˆ* (־² :: rest) := (־“ ג‹ˆ* rest) ג‹ˆ ־²` and `־“ ג‹ˆ* [] := ־“`. -/
def Shape.extList {C : Carrier} (־“ : Shape C) : List C.Arity ג†’ Shape C
  | []        => ־“
  | ־² :: rest => (Shape.extList ־“ rest) ג‹ˆ ־²

/-- Iterated extension of a shape by a list of arities. -/
scoped infixl:67 " ג‹ˆ* " => Shape.extList

@[simp] theorem Shape.extList_nil {C : Carrier} (־“ : Shape C) : ־“ ג‹ˆ* [] = ־“ := rfl

@[simp] theorem Shape.extList_cons {C : Carrier} (־“ : Shape C) (־² : C.Arity)
    (rest : List C.Arity) : ־“ ג‹ˆ* (־² :: rest) = (־“ ג‹ˆ* rest) ג‹ˆ ־² := rfl

end Action
